# ============================================================
# PORTAL CENTRAL — plantilla de variables
# ============================================================
# Este archivo es solo referencia. NO commitear los .env reales.
#
# BACKEND (Apps Script): NO usa .env. Las claves van en
# Project Settings → Script Properties (o vía PropertiesService).
# Las listamos aquí para que sirvan de checklist.
#
# FRONTEND (Vite): SÍ usa .env. Solo variables con prefijo VITE_
# se exponen al cliente. Crea `frontend/.env` con estos valores.
# ============================================================

# ── BACKEND (configurar en Apps Script Properties) ──
SHEET_ID=
DRIVE_FOLDER_VOUCHERS=
ADMIN_EMAIL=
NOTIFICACION_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_SALT=
SESSION_SECRET=
RATE_LIMIT_PER_HOUR=10
WHATSAPP_NUMBER=51984300510

# ── BACKEND extensiones futuras (no usar todavía) ──
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# STRIPE_SECRET_KEY=
# WHATSAPP_CLOUD_API_TOKEN=

# ── FRONTEND (Vite, prefijo VITE_) ──
VITE_API_URL=https://script.google.com/macros/s/PEGAR_DEPLOY_ID/exec
VITE_WHATSAPP=51984300510
